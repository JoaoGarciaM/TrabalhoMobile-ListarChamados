<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="#FFFFFF"
    android:padding="12dp"
    android:layout_marginBottom="8dp"
    android:elevation="2dp"
    android:gravity="center_vertical">

    <!-- Miniatura da imagem -->
    <ImageView
        android:id="@+id/imageViewThumbnail"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginEnd="12dp"
        android:scaleType="centerCrop"
        android:background="#E0E0E0"
        android:contentDescription="Miniatura do chamado"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textViewItemTitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Título do Problema"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#000000" />

        <TextView
            android:id="@+id/textViewItemLocal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Local"
            android:textSize="13sp"
            android:textColor="#757575"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/textViewItemDescricao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Descrição curta..."
            android:textSize="13sp"
            android:textColor="#575757"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/textViewItemSolucao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Solução: ..."
            android:textColor="#388E3C"
            android:textSize="12sp"
            android:layout_marginTop="2dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/textViewItemDataLocal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Data - Status"
            android:textColor="#555555"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Indicador de status -->
    <TextView
        android:id="@+id/textViewStatusBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:text="Aberto"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:textStyle="bold"
        android:background="#F44336"
        android:layout_marginStart="8dp" />

</LinearLayout>
