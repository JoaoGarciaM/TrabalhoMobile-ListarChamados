<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="#FFFFFF"
    android:padding="15dp"
    android:layout_marginBottom="10dp"
    android:elevation="2dp"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/imageViewIcone"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginEnd="15dp"
        android:src="@android:drawable/ic_menu_info_details" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textViewItemTitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Título do Problema"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#000000" />

        <TextView
            android:id="@+id/textViewItemDescricao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Descrição curta do problema aqui..."
            android:textSize="14sp"
            android:textColor="#575757"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/textViewItemSolucao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Solução: ..."
            android:textColor="#388E3C"
            android:textSize="13sp"
            android:layout_marginTop="4dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/textViewItemDataLocal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Data - Local - Status"
            android:textColor="#555555"
            android:textSize="12sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

</LinearLayout>